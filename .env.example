# ServiceOps Command Center — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# App
NEXT_PUBLIC_APP_NAME=
NEXT_PUBLIC_APP_URL=

# GoHighLevel Integration
GHL_API_BASE_URL=https://services.leadconnectorhq.com
GHL_LOCATION_ID=
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
GHL_PRIVATE_INTEGRATION_TOKEN=
GHL_WEBHOOK_SECRET=

# Database
DATABASE_URL=

# Supabase (if using Supabase)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Auth
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# File Storage
STORAGE_BUCKET=

# App Environment
APP_ENV=development
